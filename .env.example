# Server
PORT=           # Port the server listens on. Default: 8000
HOST=           # Host the server binds to. Default: 0.0.0.0

# Database
DATABASE_PATH=  # Path to the SQLite database file. Default: data/task-tracker.sqlite

# Auth — JWT
JWT_SECRET=     # Secret used to sign session tokens. Auto-generated to data/jwt-secret.local if not set.

# Auth — WebAuthn
WEBAUTHN_RP_ID=      # Domain only, no scheme or port (e.g. example.com). Default: localhost
WEBAUTHN_RP_ORIGIN=  # Full origin the browser uses to access the app (e.g. https://example.com). Default: http://localhost:8000
WEBAUTHN_RP_NAME=    # Display name shown in the passkey prompt. Default: Task Tracker
