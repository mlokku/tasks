{
  "scripts": {
    "build:palette": "node scripts/build-palette-css.mjs",
    "build:css": "npm run build:palette && tailwindcss -i ./static/src/app.css -o ./static/css/app.css --minify",
    "watch:css": "npm run build:palette && tailwindcss -i ./static/src/app.css -o ./static/css/app.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
